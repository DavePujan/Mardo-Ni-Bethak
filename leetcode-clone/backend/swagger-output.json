  "paths": {
    "/auth/login": {
      "post": {
        "description": "User login with rate limiting (max 10 requests per 15 min)",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "schema": {
              "type": "object",
              "properties": {
                "email": {
                  "example": "test@example.com"
                },
                "password": {
                  "example": "123456"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Login successful",
            "examples": {
              "application/json": {
                "role": "student"
              }
            }
          },
          "401": {
            "description": "Invalid credentials"
          },
          "404": {
            "description": "User not found"
          },
          "429": {
            "description": "Rate limit exceeded",
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "example": "Too many login attempts. Try again later."
                }
              }
            },
            "headers": {
              "RateLimit-Limit": {
                "type": "integer",
                "description": "Max requests allowed"
              },
              "RateLimit-Remaining": {
                "type": "integer",
                "description": "Remaining requests"
              },
              "RateLimit-Reset": {
                "type": "integer",
                "description": "Time when limit resets"
              }
            }
          },
          "503": {
            "description": "Fallback mode (Redis unavailable)",
            "examples": {
              "application/json": {
                "warning": "Redis unavailable, using in-memory rate limiting"
              }
            }
          }
        }
      }
    },
